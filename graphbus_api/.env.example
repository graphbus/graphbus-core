# GraphBus API Server — Environment Variables

# ── Firebase / Firestore ──────────────────────────────────────────
# Path to Firebase Admin SDK service account JSON
GOOGLE_APPLICATION_CREDENTIALS=~/.config/graphbus/firebase-sa.json

# Firebase project (graphbus-19688) + Firestore default database
FIREBASE_PROJECT_ID=graphbus-19688
# FIRESTORE_DATABASE=(default)   # only set if using a named database

# Alternatively, paste the SA JSON inline:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Single-key fallback (self-hosted, no Firebase) ────────────────
# Auto-generated on first start if Firebase is not configured
# GRAPHBUS_API_KEY=

# ── Server ────────────────────────────────────────────────────────
# PORT=8080

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins.
# Defaults to "*" (allow all) if not set — safe for local dev and
# private self-hosted deployments.  Set explicitly in production:
# CORS_ALLOWED_ORIGINS=https://app.graphbus.com,https://staging.graphbus.com
